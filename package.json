{
  "name": "minecraft-classic-clone",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A Minecraft Classic (2009) clone with a falsifiable test-oracle suite over the voxel core",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mutation": "stryker run",
    "mutation:clean": "node scripts/mutation-clean.mjs",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/three": "^0.169.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^3.23.2",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
