{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["progress", "clear-text", "json", "html"],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "src/core/**/*.{js,ts}",
    "src/game/**/*.{js,ts}",
    "!src/**/*.{test,spec}.*",
    "!src/core/selfcheck.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 70
  },
  "incremental": true
}
