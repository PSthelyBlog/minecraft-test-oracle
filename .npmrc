# Pin the public npm registry explicitly.
#
# All dependencies resolve to registry.npmjs.org (see package-lock.json), but with
# no .npmrc the Dependabot npm updater aborted file-fetching with
# `private_registry_config_not_found` for npm.pkg.github.com — it could not prove
# which registry to use and probed GitHub Packages. Declaring the default registry
# removes that ambiguity so Dependabot can open npm update PRs. This is a no-op for
# local/CI installs (npmjs.org is already the default).
registry=https://registry.npmjs.org/
