#!/bin/sh
#
# Local falsifiability gate — the mutation test that used to run in CI now runs here.
# Before a push whose commits touch code/test/build inputs, it runs the authoritative
# `npm run mutation:clean` and ABORTS the push if the mutation score drops below the
# break threshold (a regression / new oracle blind spot). Docs-only pushes skip it.
#
# Install once (per clone):   npm run hooks:install   (sets core.hooksPath here)
# Bypass for one push:        SKIP_MUTATION=1 git push   (use sparingly)
#
# Git passes "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin.

if [ "${SKIP_MUTATION:-}" = "1" ]; then
  echo "pre-push: SKIP_MUTATION=1 set — skipping the mutation gate."
  exit 0
fi

# Only the inputs that can change the mutation score (mirrors the CI badge job's filter).
relevant='^(src/|test/|scripts/|index\.html|package\.json|package-lock\.json|\.npmrc|stryker\.config\.json|vitest\.config\.ts|vite\.config\.ts|tsconfig\.json|\.github/workflows/ci\.yml)'
zero=0000000000000000000000000000000000000000
need=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue # branch deletion — nothing to gate
  if [ "$remote_sha" = "$zero" ]; then
    # New branch on the remote: diff against where it forked from origin/main.
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null)
    if [ -n "$base" ]; then range="$base..$local_sha"; else
      need=1
      continue
    fi
  else
    range="$remote_sha..$local_sha"
  fi
  if git diff --name-only "$range" 2>/dev/null | grep -qE "$relevant"; then
    need=1
  fi
done

if [ "$need" = "0" ]; then
  echo "pre-push: no code/test/build changes in the pushed commits — mutation gate not needed."
  exit 0
fi

echo "pre-push: running the falsifiability gate (npm run mutation:clean)…"
if npm run mutation:clean; then
  echo "pre-push: mutation gate passed."
  exit 0
fi

echo "pre-push: mutation gate FAILED — score below threshold or a new surviving mutant." >&2
echo "          Kill the survivor (or document it as equivalent), then push again." >&2
echo "          To bypass for one push: SKIP_MUTATION=1 git push" >&2
exit 1
